# ─── BANCO DE DADOS ──────────────────────────────────────────────────────────
# Local: Session mode (porta 5432) com sslmode=require
# Prod (Vercel): Transaction mode (porta 6543) com pgbouncer=true&sslmode=no-verify
DATABASE_URL=""

# ─── AUTH (NextAuth v5) ──────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── URLs PÚBLICAS ────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Metalab Store"

# ─── MERCADO PAGO (pagamento PIX) ─────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=""
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""
# Secret HMAC do painel MP → Webhooks → assinatura
MP_WEBHOOK_SECRET=""

# ─── EMAIL (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
# Em produção, trocar para domínio próprio verificado no Resend
EMAIL_FROM="Metalab <onboarding@resend.dev>"

# ─── UPLOAD (Cloudinary) ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── FRETE (Melhor Envio) ─────────────────────────────────────────────────────
MELHOR_ENVIO_TOKEN=""
MELHOR_ENVIO_ORIGIN_CEP=""
# Opcionais (defaults para suplementos): peso 0.5kg, 20x15x10cm
FRETE_PESO_KG="0.5"
FRETE_ALTURA_CM="10"
FRETE_LARGURA_CM="15"
FRETE_COMPRIMENTO_CM="20"

# ─── QSTASH (jobs assíncronos) ────────────────────────────────────────────────
# Sem essas vars, e-mails caem no fallback síncrono (jobs não rodam).
QSTASH_URL="https://qstash-eu-central-1.upstash.io"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ─── RATE LIMIT (Upstash Redis) ───────────────────────────────────────────────
# Sem essas vars, todos os rate-limiters retornam success:true (no-op).
# REATIVAR ANTES DE IR PARA PRODUÇÃO REAL.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── ANALYTICS (opcional) ─────────────────────────────────────────────────────
# Quando vazios, os scripts GA4 e Meta Pixel não são carregados.
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# ─── OBSERVABILIDADE (Sentry) ─────────────────────────────────────────────────
# Criar projeto em sentry.io → Settings → Projects → DSN
# SENTRY_DSN: server-side (não expõe no browser)
# NEXT_PUBLIC_SENTRY_DSN: client-side (pode ser público — não é segredo)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Para upload de sourcemaps no build (CI/Vercel): gerar em sentry.io → Auth Tokens
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
